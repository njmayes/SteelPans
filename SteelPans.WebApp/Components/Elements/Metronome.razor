@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="metronome">
    <div class="metronome__header">
        <div class="metronome__status">
            <span class="badge @(IsPlaying && Enabled ? "text-bg-success" : "text-bg-secondary")">
                @(IsPlaying && Enabled ? "Metronome On" : "Metronome Off")
            </span>
            <span class="metronome__status-text">Beat @displayBeat_ / @BeatsPerBar</span>
        </div>

        <button class="btn btn-outline-primary"
                type="button"
                @onclick="ToggleEnabledAsync">
            @(Enabled ? "Disable" : "Enable")
        </button>
    </div>

    <div class="metronome__controls">
        <div class="metronome__field">
            <label class="form-label" for="@($"{componentId_}_bpm")">BPM</label>
            <input id="@($"{componentId_}_bpm")"
                   class="form-control metronome__bpm-input"
                   type="number"
                   min="20"
                   max="300"
                   step="1"
                   value="@Bpm"
                   @onchange="OnBpmChanged"
                   disabled="@DisableBpmEditing" />
        </div>

        <div class="metronome__field">
            <label class="form-label" for="@($"{componentId_}_timeSignature")">Time Signature</label>
            <input id="@($"{componentId_}_timeSignature")"
                   class="form-control metronome__time-signature-input"
                   type="text"
                   value="@($"{BeatsPerBar}/{BeatUnit}")"
                   disabled="@true" />
        </div>
    </div>

    <div class="metronome__visual @(Enabled ? null : "metronome__visual--disabled")">
        <div class="metronome__case">
            <div class="metronome__arm-pivot"></div>

            <div class="metronome__arm-wrap">
                <div class="metronome__arm @(swingLeft_ ? "metronome__arm--left" : "metronome__arm--right")">
                    <div class="metronome__arm-stick"></div>
                    <div class="metronome__arm-weight"></div>
                </div>
            </div>

            <div class="metronome__scale">
                <span>Largo</span>
                <span>Andante</span>
                <span>Allegro</span>
            </div>

            <div class="metronome__light @(tickFlash_ ? (accentFlash_ ? "metronome__light--accent" : "metronome__light--tick") : null)"></div>

            <div class="metronome__beat-display">
                <span class="metronome__beat-number">@displayBeat_</span>
                <span class="metronome__beat-total">/ @BeatsPerBar</span>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public bool IsPlaying { get; set; }

    [Parameter]
    public int Bpm { get; set; } = 120;

    [Parameter]
    public EventCallback<int> BpmChanged { get; set; }

    [Parameter]
    public int BeatsPerBar { get; set; } = 4;

    [Parameter]
    public int BeatUnit { get; set; } = 4;

    [Parameter]
    public bool Enabled { get; set; } = true;

    [Parameter]
    public EventCallback<bool> EnabledChanged { get; set; }

    [Parameter]
    public bool DisableBpmEditing { get; set; }

    private readonly string componentId_ = $"metronome_{Guid.NewGuid():N}";
    private CancellationTokenSource? loopCts_;
    private int beatIndex_;
    private int displayBeat_ = 1;
    private bool previousIsPlaying_;

    private bool swingLeft_ = true;
    private bool tickFlash_;
    private bool accentFlash_;

    protected override async Task OnParametersSetAsync()
    {
        if (!Enabled)
        {
            await StopLoopAsync();
            previousIsPlaying_ = IsPlaying;
            return;
        }

        if (IsPlaying && !previousIsPlaying_)
        {
            await StartLoopAsync();
        }
        else if (!IsPlaying && previousIsPlaying_)
        {
            await StopLoopAsync();
        }

        previousIsPlaying_ = IsPlaying;
    }

    private async Task ToggleEnabledAsync()
    {
        Enabled = !Enabled;
        await EnabledChanged.InvokeAsync(Enabled);

        if (!Enabled)
            await StopLoopAsync();
        else if (IsPlaying)
            await StartLoopAsync();
    }

    private async Task OnBpmChanged(ChangeEventArgs e)
    {
        if (!int.TryParse(e.Value?.ToString(), out var bpm))
            return;

        bpm = Math.Clamp(bpm, 20, 300);

        if (Bpm == bpm)
            return;

        Bpm = bpm;
        await BpmChanged.InvokeAsync(Bpm);

        if (Enabled && IsPlaying)
            await RestartLoopAsync();
    }

    private async Task RestartLoopAsync()
    {
        await StopLoopAsync();
        await StartLoopAsync();
    }

    private async Task StartLoopAsync()
    {
        await StopLoopAsync();

        if (!Enabled || !IsPlaying)
            return;

        loopCts_ = new CancellationTokenSource();
        var token = loopCts_.Token;

        beatIndex_ = 0;
        displayBeat_ = 1;
        swingLeft_ = true;
        tickFlash_ = false;
        accentFlash_ = false;

        _ = RunLoopAsync(token);

        await Task.CompletedTask;
    }

    private async Task RunLoopAsync(CancellationToken cancellationToken)
    {
        try
        {
            while (!cancellationToken.IsCancellationRequested)
            {
                var bpm = Math.Clamp(Bpm, 20, 300);
                var beatsPerBar = Math.Max(1, BeatsPerBar);
                var interval = TimeSpan.FromMinutes(1.0 / bpm);

                var isAccent = beatIndex_ % beatsPerBar == 0;
                displayBeat_ = (beatIndex_ % beatsPerBar) + 1;

                swingLeft_ = !swingLeft_;
                tickFlash_ = true;
                accentFlash_ = isAccent;

                await InvokeAsync(StateHasChanged);
                await JS.InvokeVoidAsync("steelPan.playMetronomeTick", isAccent);

                _ = ClearFlashSoonAsync();

                beatIndex_++;
                await Task.Delay(interval, cancellationToken);
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task ClearFlashSoonAsync()
    {
        try
        {
            await Task.Delay(90);
            tickFlash_ = false;
            accentFlash_ = false;
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
        }
    }

    private async Task StopLoopAsync()
    {
        if (loopCts_ is null)
            return;

        loopCts_.Cancel();
        loopCts_.Dispose();
        loopCts_ = null;

        tickFlash_ = false;
        accentFlash_ = false;
        beatIndex_ = 0;
        displayBeat_ = 1;

        await InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        await StopLoopAsync();
    }
}
