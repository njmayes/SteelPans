<div class="assigned-pan-toolbar__volume" title="Playback Volume">
    <button type="button"
            class="assigned-pan-toolbar__volume-button"
            @onclick="ToggleMute"
            aria-label="Toggle mute">
        <span class="bi @(EffectiveVolume <= 0.0001 ? "bi-volume-mute-fill"
                                                                          : EffectiveVolume < 0.5 ? "bi-volume-down-fill"
                                                                                                  : "bi-volume-up-fill")"></span>
    </button>

    <input class="assigned-pan-toolbar__volume-slider"
           type="range"
           min="0"
           max="100"
           step="1"
           value="@VolumePercent"
           @oninput="OnVolumeInput" />

    <span class="assigned-pan-toolbar__volume-value">@VolumePercent%</span>
</div>

@code {
    [Parameter] public double Volume { get; set; } = 1.0;
    [Parameter] public EventCallback<double> VolumeChanged { get; set; }

    private double previousNonZeroVolume_ = 1.0;

    private int VolumePercent => (int)Math.Round(EffectiveVolume * 100.0);
    private double EffectiveVolume => Math.Clamp(Volume, 0.0, 1.0);

    private async Task OnVolumeInput(ChangeEventArgs e)
    {
        if (e.Value?.ToString() is not { Length: > 0 } raw ||
            !int.TryParse(raw, out var percent))
            return;

        var volume = Math.Clamp(percent / 100.0, 0.0, 1.0);

        if (volume > 0.0)
            previousNonZeroVolume_ = volume;

        await VolumeChanged.InvokeAsync(volume);
    }

    private async Task ToggleMute()
    {
        if (EffectiveVolume <= 0.0001)
        {
            var restored = previousNonZeroVolume_ > 0.0 ? previousNonZeroVolume_ : 1.0;
            await VolumeChanged.InvokeAsync(restored);
            return;
        }

        previousNonZeroVolume_ = EffectiveVolume;
        await VolumeChanged.InvokeAsync(0.0);
    }
}