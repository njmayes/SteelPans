@using Microsoft.AspNetCore.Components.Forms
@using SteelPans.WebApp.Components
@using SteelPans.WebApp.Model
@using SteelPans.WebApp.Extensions

<div class="sp-section midi-loader @(Disabled ? "midi-loader--disabled" : null)">
    <div class="midi-loader__top">
        <label class="form-label">MIDI file</label>
    </div>

    <div class="midi-loader__row @(HasTracks ? "midi-loader__row--with-menu" : null)">
        <div class="midi-loader__file">
            <FilePicker FileName="@FileName"
                        OnSingleFileSelected="OnSingleMidiSelected"
                        OnMultipleFileSelected="OnMultipleMidiSelected"
                        Accept="@(["mid", "midi"])" />
        </div>

        @if (HasTracks)
        {
            <div class="midi-loader__menu-wrap">
                <button type="button"
                        class="midi-loader__menu-button"
                        title="Show tracks"
                        aria-label="Show tracks"
                        aria-expanded="@showTrackOverlay_.ToString().ToLowerInvariant()"
                        @onclick="ToggleTrackOverlay">
                    <span class="bi bi-music-note-list"></span>
                </button>

                @if (showTrackOverlay_)
                {
                    <div class="midi-loader__track-overlay">
                        <div class="midi-loader__track-overlay-header">
                            <span class="midi-loader__track-overlay-title">Tracks</span>
                            <button type="button"
                                    class="midi-loader__track-overlay-close"
                                    aria-label="Close tracks"
                                    @onclick="CloseTrackOverlay">
                                <span class="bi bi-x-lg"></span>
                            </button>
                        </div>

                        <div class="midi-loader__track-list">
                            @foreach (var track in Tracks)
                            {
                                <div class="midi-loader__track-item">
                                    <div class="midi-loader__track-name">@GetTrackDisplay(track)</div>
                                    <div class="midi-loader__track-meta">
                                        @track.NoteCount note@(track.NoteCount == 1 ? "" : "s")
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public string FileName { get; set; } = string.Empty;

    [Parameter]
    public IReadOnlyList<MidiTrackInfo> Tracks { get; set; } = [];

    [Parameter]
    public EventCallback<IBrowserFile> OnSingleMidiSelected { get; set; }

    [Parameter]
    public EventCallback<IReadOnlyList<IBrowserFile>> OnMultipleMidiSelected { get; set; }

    private bool HasTracks => Tracks.Count > 0;
    private bool showTrackOverlay_;

    private void ToggleTrackOverlay()
    {
        showTrackOverlay_ = !showTrackOverlay_;
    }

    private void CloseTrackOverlay()
    {
        showTrackOverlay_ = false;
    }

    private static string GetTrackDisplay(MidiTrackInfo track)
    {
        var name = string.IsNullOrWhiteSpace(track.Name)
            ? $"Track {track.Index + 1}"
            : track.Name.Trim();

        return $"{track.Index + 1}. {name}";
    }
}