<div class="@ShellClass">
    <button class="@ToggleButtonClass"
            type="button"
            @onclick="ToggleAsync"
            aria-expanded="@IsOpen"
            aria-label="@Label">
        <i class="@IconClass pans-page__overlay-toggle-icon" aria-hidden="true"></i>
        <span class="pans-page__overlay-toggle-label">@Label</span>
    </button>

    @if (IsOpen)
    {
        <div class="@BodyWrapClass">
            <div class="@BodyClass">
                @ChildContent
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public string Side { get; set; } = "left";

    [Parameter]
    public string Label { get; set; } = string.Empty;

    [Parameter]
    public string IconClass { get; set; } = "bi bi-sliders";

    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public EventCallback<bool> IsOpenChanged { get; set; }

    [Parameter]
    public string? PanelVariantClass { get; set; }

    [Parameter]
    public string? BodyVariantClass { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private string ShellClass =>
        string.Join(
            " ",
            new[]
            {
                "pans-page__overlay-shell",
                $"pans-page__overlay-shell--{Side}",
                IsOpen ? "pans-page__overlay-shell--open" : "pans-page__overlay-shell--closed"
            });

    private const string ToggleButtonClass = "pans-page__overlay-toggle pans-page__overlay-toggle--shell";

    private string BodyWrapClass =>
        string.Join(
            " ",
            new[]
            {
                "pans-page__overlay-panel-body-wrap",
                IsOpen ? "pans-page__overlay-panel-body-wrap--open" : "pans-page__overlay-panel-body-wrap--closed",
                PanelVariantClass
            }.Where(static x => !string.IsNullOrWhiteSpace(x)));

    private string BodyClass =>
        string.Join(
            " ",
            new[]
            {
                "pans-page__overlay-panel-body",
                BodyVariantClass
            }.Where(static x => !string.IsNullOrWhiteSpace(x)));

    private async Task ToggleAsync()
    {
        await IsOpenChanged.InvokeAsync(!IsOpen);
    }
}